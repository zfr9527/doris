# Environment variables for LDAP service configuration

# Host ports mapping
# You can change the host port (the one on the left) to avoid conflicts.
LDAP_HOST_NAME=openldap
LDAP_HOST_PORT=389
LDAPS_HOST_PORT=636
PHPLDAPADMIN_HOST_PORT=8088

# OpenLDAP server settings
LDAP_ORGANISATION="Apache Doris"
LDAP_DOMAIN="doris.apache.org"
LDAP_ADMIN_PASSWORD="admin_password"
LDAP_CONFIG_PASSWORD="config_password"

# phpLDAPadmin settings
# This should match the service name of the ldap container in the yaml file.
PHPLDAPADMIN_LDAP_HOSTS=openldap
PHPLDAPADMIN_HOST_NAME=phpldapadmin